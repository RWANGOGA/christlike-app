# ==================== FRONTEND ====================
# The URL of your backend API (Change this to your Render URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== BACKEND ====================
# PostgreSQL Database URL (Render will provide this in production)
DATABASE_URL=postgresql://user:password@localhost:5432/christlike_db

# JWT Secret Key (Use a long, random string in production)
SECRET_KEY=your-super-secret-key-change-in-production-12345

# Comma-separated list of emails that automatically become Admins
ADMIN_EMAILS=akjonan256@gmail.com
